# =============================================================================
# rdfsolve — Dockerfile
# =============================================================================
#
# WHAT THIS FILE DOES
# -------------------
# Builds a single self-contained Docker image that serves the entire rdfsolve
# application: a Python/Flask REST API backend plus a compiled TypeScript
# frontend, all behind a Gunicorn HTTP server on port 8000.
#
# HOW TO BUILD & RUN (normally you use docker-compose.yml instead — see below)
# ----------------------------------------------------------------------------
#   docker build -f docker/Dockerfile -t rdfsolve .
#   docker run -p 8000:8000 rdfsolve
#
# The preferred way is via docker-compose.yml at the repo root:
#   docker compose up --build       # build the image and start the container
#   docker compose up -d --build    # same, but detached (runs in background)
#   docker compose down             # stop and remove the container
#
# MULTI-STAGE BUILD OVERVIEW
# --------------------------
# Building two things in one Dockerfile would normally produce a bloated image
# full of Node.js tooling that the Python server never needs at runtime.
# A multi-stage build solves this: we use a temporary Node container (Stage 1)
# just to compile the TypeScript → JavaScript bundle, then copy only the
# compiled output into the final Python container (Stage 2).
# The Node.js tools are discarded automatically — they never end up in the
# image that gets deployed.
#
# ABOUT THE DATABASE
# ------------------
# rdfsolve stores all its data (schemas, mappings) in a single SQLite file.
# SQLite is a file-based database — the entire database is one file on disk.
#
# Inside the container the file lives at:  /app/data/rdfsolve.db
#
# docker-compose.yml mounts a Docker "named volume" at /app/data so that this
# file survives container restarts and image rebuilds.  Without that volume
# mount the database would be wiped every time you run `docker compose down`.
#
# WHAT'S IN THE DATABASE AT STARTUP
# ----------------------------------
# The container starts empty (new database).  On first boot Flask calls
# SchemaService.import_from_directory(), which reads every *.jsonld file from
# /app/schemas/ (mounted from docker/schemas/ in the repo) and inserts them
# into the `schemas` table.  Those pre-mined schema files ARE tracked in git
# (see docker/schemas/) so the database is populated automatically and
# consistently across machines.
#
# The `schemas` table has a `strategy` column that labels rows as either:
#   "miner"            — a schema extracted by the SPARQL miner
#   "instance_matcher" — a mapping generated by the instance matcher
#
# MANAGING THE DATABASE
# ---------------------
# To inspect the live database from your host machine:
#   docker exec -it rdfsolve sqlite3 /app/data/rdfsolve.db
#   > .tables
#   > SELECT id, strategy, pattern_count FROM schemas;
#   > .quit
#
# To wipe the database and start fresh (re-imports everything from /app/schemas/
# on the next `docker compose up`):
#   docker compose down -v          # -v removes the named volume too
#   docker compose up -d
#
# To back up the database to your host:
#   docker cp rdfsolve:/app/data/rdfsolve.db ./rdfsolve_backup.db
#
# GIT & THE DATABASE
# ------------------
# The SQLite database file is NOT tracked in git (it's in .gitignore).
# Neither are *.jsonld schema files — they are generated artefacts that you
# produce locally with the mining CLI and place in docker/schemas/ before
# building.  The .gitignore rule "*.jsonld" (with an exception for
# tests/test_data/) ensures they are never accidentally committed.
#
# To generate schemas for the docker/schemas/ directory:
#   rdfsolve mine --output-dir docker/schemas
#   rdfsolve instance-match seed --output-dir docker/schemas
#
# After generating, rebuild the image to bake the new files in (or just
# restart — docker-compose.yml bind-mounts the directory at runtime so
# changes are picked up immediately without a rebuild):
#   docker compose restart
#
# On a fresh clone with no pre-generated schemas:
#   1. Run the mining CLI commands above to populate docker/schemas/.
#   2. Run docker compose up --build.
#   The database will be populated from those files on first boot.
# =============================================================================


# =============================================================================
# STAGE 1 — Build the TypeScript frontend bundle
# =============================================================================
# We use the official Node 20 image (Alpine = small Linux variant) just for
# this compilation step.  Nothing from this stage ends up in the final image
# except the compiled JavaScript and HTML files.
FROM node:20-alpine AS frontend-builder

WORKDIR /build

# Copy only the package manifests first so Docker can cache the npm install
# layer independently from the source code.  npm install only re-runs when
# package.json / package-lock.json actually change.
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci --ignore-scripts
# npm ci = clean install — strictly follows package-lock.json, reproducible.
# --ignore-scripts skips any postinstall scripts for security.

# Now copy the TypeScript source files and the HTML entry point.
COPY frontend/tsconfig.json ./
COPY frontend/src/ src/
COPY frontend/demo/index.html ./

# Compile TypeScript → JavaScript using esbuild (fast JS bundler).
# Output: out/dist/bundle.js  (single minified file with sourcemap)
# --bundle  : resolve all imports into one file
# --format=esm : use modern ES module syntax
# --target=es2020 : generate code compatible with modern browsers
# --sourcemap : generate a .js.map file so browser devtools show TS line numbers
# --minify : shrink the file for faster download
RUN npx esbuild src/api-entry.ts \
    --bundle \
    --outfile=out/dist/bundle.js \
    --format=esm \
    --target=es2020 \
    --sourcemap \
    --minify

# Move index.html next to the dist/ folder so the server can find both.
RUN cp index.html out/


# =============================================================================
# STAGE 2 — Python backend (this is the final image that gets deployed)
# =============================================================================
FROM python:3.13-slim
# python:3.13-slim is the official Python image without development tools,
# keeping the image small while still having everything Python needs.

WORKDIR /app
# All paths below are relative to /app inside the container.

# ---------------------------------------------------------------------------
# Install uv — a fast Python package manager (replaces pip for speed).
# We copy just the two uv binaries from their official Docker image rather
# than running a curl | bash installer, which is more reproducible.
# ---------------------------------------------------------------------------
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# ---------------------------------------------------------------------------
# Install the rdfsolve Python package.
#
# We copy the package metadata files first (pyproject.toml etc.) so Docker
# can cache the pip install layer.  If only source code changes but not
# dependencies, Docker reuses the cached install layer — much faster rebuilds.
#
# ".[web]" installs rdfsolve plus its optional web dependencies:
#   Flask, Gunicorn, flask-cors, pandas, etc.
# ---------------------------------------------------------------------------
COPY pyproject.toml README.md CITATION.cff LICENSE ./
COPY src/ src/
RUN uv pip install --system --no-cache ".[web]"
# --system  : install into the system Python (no virtualenv needed in Docker)
# --no-cache: don't cache downloaded wheels in the image (keeps image smaller)

# ---------------------------------------------------------------------------
# Seed schemas — pre-mined JSON-LD files that populate the database on boot.
#
# These files live in docker/schemas/ in the git repository and ARE committed
# to git.  They represent the stable, curated set of dataset schemas.
#
# On container startup, Flask's SchemaService.import_from_directory() reads
# every *.jsonld from /app/schemas/ and upserts them into the `schemas` table.
#
# To add a new schema to the corpus without rebuilding from scratch:
#   1. Drop the new *.jsonld into docker/schemas/ on your host.
#   2. The docker-compose.yml mounts that directory at /app/schemas/:ro
#      so the file is visible to the running container immediately.
#   3. Restart Flask (docker compose restart) — it re-imports on every boot.
#
# To regenerate all schemas from the live SPARQL endpoints:
#   rdfsolve mine --output-dir docker/schemas --format jsonld --no-counts
# (run this locally before rebuilding the image)
# ---------------------------------------------------------------------------
COPY docker/schemas/ /app/schemas/

# ---------------------------------------------------------------------------
# Copy helper data and scripts that may be useful inside the container for
# on-demand operations.  These are NOT used automatically at runtime.
#
# data/sources.csv  — list of all known SPARQL endpoints with their names,
#                     endpoint URLs, and graph URIs.  Used by the miner when
#                     called manually inside the container.
# data/qlever.csv   — subset of endpoints served by the QLever engine.
# scripts/mine_all_sources.py — the schema miner script, usable via:
#   docker exec rdfsolve python /app/scripts/mine_all_sources.py --help
# ---------------------------------------------------------------------------
COPY data/sources.csv /app/data/sources.csv
COPY data/qlever.csv /app/data/qlever.csv
COPY scripts/mine_all_sources.py /app/scripts/mine_all_sources.py

# Copy the compiled frontend files from Stage 1 into this image.
# /app/frontend/ will contain: index.html + dist/bundle.js + dist/bundle.js.map
COPY --from=frontend-builder /build/out/ /app/frontend/

# ---------------------------------------------------------------------------
# Runtime environment variables — defaults baked into the image.
# All of these can be overridden in docker-compose.yml or at `docker run` time
# with  -e VARIABLE=value  or  --env-file .env.
#
# DATABASE_PATH   — where SQLite writes the .db file.
#                   IMPORTANT: this path must be inside the volume mount
#                   (/app/data) defined in docker-compose.yml, otherwise the
#                   database is lost when the container stops.
# SCHEMA_IMPORT_DIR — directory Flask scans for *.jsonld files on startup.
# FRONTEND_DIST   — directory Flask serves as static files (the UI).
# FLASK_DEBUG     — set to "1" to enable Flask's debug mode (hot reload, etc.).
#                   Never use "1" in production.
# CORS_ORIGINS    — which browser origins may call the API.  "*" = any origin.
# PORT            — the port Gunicorn listens on inside the container.
#                   The docker-compose.yml maps this to the same host port.
# PYTHONUNBUFFERED — forces Python to print logs immediately (no buffering),
#                   so `docker logs` shows output in real time.
# ---------------------------------------------------------------------------
ENV DATABASE_PATH=/app/data/rdfsolve.db \
    SCHEMA_IMPORT_DIR=/app/schemas \
    FRONTEND_DIST=/app/frontend \
    FLASK_DEBUG=0 \
    CORS_ORIGINS=* \
    PORT=8000 \
    PYTHONUNBUFFERED=1

# Ensure /app/data/ exists.  docker-compose.yml mounts a named volume here,
# but when running the image directly (without compose) this directory must
# exist or SQLite will fail to create the database file.
RUN mkdir -p /app/data

# Tell Docker which port the application listens on (documentation only —
# this does not publish the port; the docker-compose.yml `ports:` section
# does the actual host ↔ container port binding).
EXPOSE ${PORT}

# ---------------------------------------------------------------------------
# Start the application.
# Gunicorn is a production-grade WSGI server for Python web apps.
# It spawns multiple worker processes so the app can handle concurrent requests.
#
# --bind "0.0.0.0:${PORT}"  listen on all network interfaces inside the container
# --workers 2               two parallel worker processes (tune up for more load)
# --timeout 120             kill a worker if a request takes longer than 120 s
#                           (SPARQL queries against slow endpoints can be slow)
#
# "rdfsolve.backend.app:create_app()" tells Gunicorn where the Flask app is:
#   module path : rdfsolve.backend.app
#   factory call: create_app()   (Flask application factory pattern)
# ---------------------------------------------------------------------------
CMD gunicorn \
    --bind "0.0.0.0:${PORT}" \
    --workers 2 \
    --timeout 120 \
    "rdfsolve.backend.app:create_app()"
