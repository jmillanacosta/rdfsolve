# .env.example — copy to .env and fill in values
# Used by docker-compose.full.yml for the full stack (backend + MCP).

# Port the rdfsolve Flask backend listens on
BACKEND_PORT=8000

# Port the rdfsolve-mcp service listens on
MCP_PORT=8001

# OpenAI API key for the IntentParser (leave blank to use regex fallback)
OPENAI_API_KEY=

# OpenAI model for structured intent extraction
OPENAI_MODEL=gpt-4o

# CORS origins allowed to call the API (comma-separated or *)
CORS_ORIGINS=*

# SPARQL endpoint timeout in seconds
SPARQL_TIMEOUT=60
